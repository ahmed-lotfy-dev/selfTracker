{
  "expo": {
    "name": "selfTracker",
    "slug": "selftracker",
    "version": "1.1.5",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": [
      "selftracker",
      "exp+selftracker"
    ],
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.ahmedlotfy.selftracker",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "googleServicesFile": "./google-services.json",
      "package": "com.ahmedlotfy.selftracker",
      "versionCode": 13,
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-updates",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-screen.png",
          "imageWidth": 600,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "The app accesses your photos to let you share them with your friends.",
          "cameraPermission": "Allow $(selfTracker) to access your camera."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/ic_launcher.png",
          "color": "#ffffff",
          "defaultChannel": "default",
          "sounds": [
            "./assets/notification_sound.wav"
          ],
          "enableBackgroundRemoteNotifications": false
        }
      ],
      [
        "expo-secure-store"
      ],
      "expo-font",
      "expo-web-browser",
      "./plugins/withDisableLinting",
      "expo-sharing",
      "@react-native-community/datetimepicker",
      "expo-sqlite",
      "expo-status-bar"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "6cb0f186-29d6-46d3-baa5-af88fdccee50"
      }
    },
    "owner": "ahmed-lotfy",
    "runtimeVersion": "1.1.5",
    "updates": {
      "enabled": true,
      "fallbackToCacheTimeout": 0,
      "url": "https://u.expo.dev/6cb0f186-29d6-46d3-baa5-af88fdccee50"
    }
  }
}

{
  "name": "backend",
  "type": "module",
  "scripts": {
    "dev": "bun run --hot src/index.ts",
    "start": "bun run src/index.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:drop": "bun run ./src/db/seed/dropAllTables.ts",
    "db:seed": "bun run ./src/db/seed/seed.ts",
    "db:seed:demo": "bun run ./scripts/seed-demo-data.ts",
    "ai:backfill": "bun run ./src/scripts/backfill-embeddings.ts",
    "ai:debug-rag": "bun run ./src/scripts/debug-ai-rag.ts"
  },
  "dependencies": {
